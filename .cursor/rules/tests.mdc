## NLP / SQL validator testleri

LLM'in ürettiği SQL'in güvenli olduğunu doğrulamak için:

```python
def test_validate_sql_rejects_column_named_delete():
    """'deletion_at' kolon adı keyword-match nedeniyle reddedilmemeli."""
    from app.services.nlp_assistant import _validate_sql
    sql = "SELECT id, deletion_at FROM products WHERE tenant_id = :tid LIMIT 5"
    _validate_sql(sql, allowed_tables={"products"})  # exception atmaz

def test_validate_sql_rejects_insert(...):
    with pytest.raises(UnsafeSQL):
        _validate_sql("INSERT INTO products ...", allowed_tables={"products"})

def test_validate_sql_rejects_two_statements(...):
    with pytest.raises(UnsafeSQL):
        _validate_sql("SELECT 1; SELECT 2", allowed_tables=set())

def test_validate_sql_requires_tid_when_not_admin(...):
    with pytest.raises(UnsafeSQL):
        _validate_sql("SELECT id FROM products", allowed_tables={"products"}, cross_tenant=False)
```

## Schema-model drift testi

NLP prompt'undaki schema, gerçek modellerle uyumlu olmalı:

```python
def test_nlp_schema_doc_matches_models():
    from app.models.base import Base
    from app.services._schema_doc import build_nlp_schema_doc
    doc = build_nlp_schema_doc(Base.metadata)
    # Hayalet tablolar yok:
    assert "finance_records" not in doc
    assert "employees" not in doc
    # Gerçek kolonlar var:
    assert "change" in doc          # stock_movements.change (quantity_change DEĞİL)
    assert "customer_type" in doc   # customers.customer_type (city DEĞİL)
    assert "contact_person" in doc  # suppliers.contact_person (contact_name DEĞİL)
    # Yanlış kolonlar yok:
    assert "quantity_change" not in doc
    assert "contact_name" not in doc
```

## WebSocket testleri

```python
def test_ws_uses_tid_claim_not_tenant_id(db_session, test_tenant, test_admin):
    """JWT 'tid' claim'i okunmalı; 'tenant_id' fallback yok."""
    from app.core.security import create_access_token, decode_access_token
    token = create_access_token(
        user_id=test_admin.id, tenant_id=test_tenant.id,
        role="admin", email=test_admin.email,
    )
    payload = decode_access_token(token)
    assert payload["tid"] == test_tenant.id
    assert "tenant_id" not in payload  # eski yanlış key yok

def test_ws_rejects_token_without_tid(monkeypatch):
    """Manuel tid'siz token üret → WS handshake reddetmeli."""
    import jwt as jwtlib
    from app.core.config import settings
    bad_token = jwtlib.encode(
        {"sub": "1", "role": "admin", "typ": "access", "exp": 9999999999},
        settings.JWT_SECRET_KEY, algorithm=settings.JWT_ALGORITHM
    )
    # TestClient WS:
    from starlette.testclient import TestClient
    from app.main import app
    with TestClient(app) as tc:
        with pytest.raises(Exception):  # WebSocketDisconnect veya 1008
            with tc.websocket_connect(f"/api/ws/notifications?access_token={bad_token}"):
                pass
```

